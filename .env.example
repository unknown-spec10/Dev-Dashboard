# ⚡ Dev Dashboard - Environment Variables Configuration (Production Template)
# Copy this file to '.env' and configure variables for your target deployment environment.

# ------------------------------------------------------------------------------
# 🔐 Core Security Settings
# ------------------------------------------------------------------------------
# SECRET_KEY is used for signing JWT access tokens and WebSocket handshake signatures.
# CRITICAL: In production, generate a secure random hex key using:
# openssl rand -hex 32
SECRET_KEY=dev-dashboard-secret-key-change-me-in-production

# VAULT_ENCRYPTION_KEY is a 32-byte Fernet key (urlsafe base64-encoded) used for encrypting
# LLM provider keys in the vault database.
# CRITICAL: Generate a unique Fernet key in Python via:
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
VAULT_ENCRYPTION_KEY=

# ------------------------------------------------------------------------------
# 🗄️ Database & Cache Settings
# ------------------------------------------------------------------------------
# PostgreSQL connection parameters (used by postgres container)
POSTGRES_DB=dev_dashboard
POSTGRES_USER=postgres
# CRITICAL: Change this password in production to a secure random string
POSTGRES_PASSWORD=postgres

# Mapped Postgres Sync/Async URIs (internal container hostname 'db' matches service name)
POSTGRES_ASYNC_URI=postgresql+asyncpg://postgres:postgres@db:5432/dev_dashboard
POSTGRES_SYNC_URI=postgresql+psycopg2://postgres:postgres@db:5432/dev_dashboard

# Redis Broker (internal container hostname 'redis' matches service name)
REDIS_URI=redis://redis:6379/0

# ------------------------------------------------------------------------------
# 🌐 Real Google OAuth2 Configuration
# ------------------------------------------------------------------------------
# Create an OAuth client in the Google Cloud Console (https://console.cloud.google.com/)
# Set Authorized Redirect URIs to: http://<your-ec2-domain-or-ip>/api/auth/oauth/google/callback
# Or http://localhost:8000/api/auth/oauth/google/callback for local testing
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Set to match your deployment hostname, e.g., http://<your-ec2-domain-or-ip>/api/auth/oauth/google/callback
GOOGLE_REDIRECT_URI=http://localhost:8000/api/auth/oauth/google/callback

# ------------------------------------------------------------------------------
# 🖥️ Frontend Client URL
# ------------------------------------------------------------------------------
# Used for OAuth callbacks redirecting back to the React user interface.
# Set to match your deployment hostname, e.g., http://<your-ec2-domain-or-ip>
FRONTEND_URL=http://localhost:5173
